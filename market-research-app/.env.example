# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Primary connection string (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/marketai_db

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000

# ─── Authentication ───────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── External Data Sources ────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=
CENSUS_API_KEY=

# ─── Storage ──────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=marketai-reports
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@marketai.com
