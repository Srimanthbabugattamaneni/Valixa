# ─────────────────────────────────────────────────────────────────────────────
# MarketSense AI — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit your .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=MarketSense AI
APP_VERSION=1.0.0
ENV=development           # development | staging | production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/your_database
# Supabase:  postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── AI Provider (Anthropic Claude) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...           # Required — your Anthropic API key
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=1024                     # Max tokens per section (256–4096)
AI_TEMPERATURE=0.3                     # 0 = deterministic, 1 = creative
AI_TIMEOUT_SECONDS=90                  # Per-request timeout in seconds
AI_MAX_CONCURRENCY=6                   # Max parallel AI calls per report

# ── Market Data APIs (all optional — degrades gracefully if unset) ───────────
GOOGLE_PLACES_API_KEY=               # Google Places + Geocoding API key
YELP_API_KEY=                        # Yelp Fusion API key
CENSUS_API_KEY=                      # US Census API key (optional, raises rate limit)
SERP_API_KEY=                        # SerpAPI key for search trend signals

# ── Service-to-service auth ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must match AI_SERVICE_API_KEY in the Next.js .env.local
API_SECRET_KEY=your-secret-key-here

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000"]   # Restrict in production

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR | CRITICAL
